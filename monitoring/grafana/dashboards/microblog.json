{
  "id": null,
  "title": "MicroBlog Dashboard",
  "tags": ["microblog"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (all services)",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Request Latency p95 (all services)",
      "type": "graph",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "graph",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}} errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active HTTP Connections",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(http_requests_in_progress) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
