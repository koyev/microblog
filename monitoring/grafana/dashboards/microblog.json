{
  "id": null,
  "uid": "microblog",
  "title": "MicroBlog Dashboard",
  "tags": ["microblog"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Throughput — Requests / sec",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, job))",
          "legendFormat": "{{job}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, job))",
          "legendFormat": "{{job}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, job))",
          "legendFormat": "{{job}} p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate — 5XX / sec",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}} 5xx"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Requests (in-flight)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
