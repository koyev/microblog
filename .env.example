# Infrastructure credentials — used by Postgres, RabbitMQ, Grafana containers
# NOT loaded by Python services directly (they use their own per-service .env)

POSTGRES_USER=user
POSTGRES_PASSWORD=changeme

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=changeme

GRAFANA_ADMIN_PASSWORD=changeme

RAILWAY_PROJECT_ID=something-something-something
RAILWAY_TOKEN=something-something-something